{

    "extensions.autoUpdate": "off",
    "extensions.autoCheckUpdates": false,
    "update.mode": "manual",
    "security.workspace.trust.untrustedFiles": "open",
    "go.gopath": "/Users/rch/codecdn/sudo.wtf",
    "EIDE.Repository.UseProxy": false,
    "lean4.alwaysAskBeforeInstallingLeanVersions": true,
    "terminal.integrated.env.osx": {
        "FIG_NEW_SESSION": "1"
    },
    "git.openRepositoryInParentFolders": "always",
    "makefile.configureOnOpen": false,
    "application.shellEnvironmentResolutionTimeout": 100,
    "js/ts.inlayHints.functionLikeReturnTypes.enabled": true,
    "occult.lsp.path": "/Users/rch/repo/occult/bin/occult-lsp",
    "autoHide.autoHideSideBar": false,
    "editor.unicodeHighlight.ambiguousCharacters": false,
    "editor.semanticHighlighting.enabled": true,
    "editor.tabCompletion": "on",
    "workbench.editor.highlightModifiedTabs": true,
    "workbench.editor.showTabIndex": true,
    "workbench.editor.wrapTabs": true,
    "window.density.editorTabHeight": "compact",

    // Aesthetic
    "editor.fontFamily": "Fira Code, Menlo, monospace",
    "editor.fontLigatures": false,
    "editor.fontSize": 13,
    "editor.cursorBlinking": "phase",
    "editor.cursorSmoothCaretAnimation": "on",
    "editor.smoothScrolling": true,
    "workbench.list.smoothScrolling": true,
    "editor.bracketPairColorization.enabled": true,
    "editor.guides.bracketPairs": "active",
    "workbench.productIconTheme": "el-vsc-product-icon-theme",
    "workbench.iconTheme": "file-icons",
    "window.titleBarStyle": "native",

    // Information density
    "editor.minimap.enabled": true,
    "editor.minimap.renderCharacters": false,
    "editor.minimap.maxColumn": 80,
    "editor.stickyScroll.enabled": true,
    "editor.renderWhitespace": "selection",
    "editor.renderLineHighlight": "all",
    "breadcrumbs.enabled": true,
    "outline.showVariables": false,

    // Performance / noise reduction
    "editor.quickSuggestions": { "strings": "off" },
    "editor.parameterHints.cycle": true,
    "files.trimTrailingWhitespace": true,
    "files.insertFinalNewline": true,
    "files.trimFinalNewlines": true,
    "search.exclude": {
        "**/node_modules": true,
        "**/vendor": true,
        "**/.git": true,
        "**/dist": true,
        "**/old": true
    },

    // Terminal
    "terminal.integrated.fontFamily": "Menlo",
    "terminal.integrated.fontSize": 13,
    "terminal.integrated.cursorStyle": "block",
    "terminal.integrated.smoothScrolling": true,

    // Git
    "git.autofetch": true,
    "git.confirmSync": false,
    "git.enableSmartCommit": true,
    "gitlens.codeLens.enabled": false,
    "gitlens.currentLine.enabled": true,

    // Error lens (you have it installed)
    "errorLens.messageBackgroundMode": "none",
    "errorLens.fontStyleItalic": true,
    "errorLens.fontSize": "0.85em",

    "editor.semanticTokenColorCustomizations": {
        "[Vaporwave]": {
            "enabled": true,
            "rules": {
                "keyword": {
                    "foreground": "#ff00f8",
                    "bold": true
                },
                "operator": {
                    "foreground": "#ff00f8",
                    "bold": true
                },
                "function": "#5cecff",
                "method": "#5cecff",
                "type": {
                    "foreground": "#ffb1fe",
                    "bold": true
                },
                "namespace": "#5cecff",
                "namespace.defaultLibrary": "#5cecff",
                "property": "#5cecff",
                "string": "#fbb725",
                "parameter": "#bafffd",
                "variable.declaration": "#ffb1fe",
                "variable.declaration.existential": {
                    "foreground": "#ff00f8",
                    "bold": true
                }
            }
        }
    },
    "editor.tokenColorCustomizations": {
        "[Vaporwave]": {
            "textMateRules": [
                {
                    "scope": "keyword.operator.word.occult",
                    "settings": {
                        "foreground": "#ff00f8",
                        "fontStyle": "bold"
                    }
                },
                {
                    "scope": "keyword.control.occult",
                    "settings": {
                        "foreground": "#ff00f8",
                        "fontStyle": "bold"
                    }
                },
                {
                    "scope": "variable.parameter.definition.occult",
                    "settings": {
                        "foreground": "#bafffd"
                    }
                },
                {
                    "scope": "variable.other.definition.occult",
                    "settings": {
                        "foreground": "#ffb1fe"
                    }
                }
            ]
        }
    },
    "[occult]": {
        "editor.semanticHighlighting.enabled": false
    },

    // Todo tree (you have it installed)
    "todo-tree.highlights.defaultHighlight": {
        "foreground": "#fbb725",
        "type": "text"
    },
    "todo-tree.highlights.customHighlight": {
        "FIXME": { "foreground": "#ff0099", "icon": "flame" },
        "HACK": { "foreground": "#ff00f8", "icon": "alert" },
        "BUG": { "foreground": "#ff0099", "icon": "bug" }
    },
    "workbench.colorTheme": "Vaporwave",
    "lldb.suppressUpdateNotifications": true,
    "whiteviz.enabled": false,
    "[markdown]": {
        "editor.defaultFormatter": "yzhang.markdown-all-in-one"
    }
}
