maximize = true
quit-after-last-window-closed = true
confirm-close-surface = always

# font-family = JetBrains Mono
font-family = Fira Code
font-size = 18
font-feature = -liga

keybind = unconsumed:super+c=copy_to_clipboard

# Pass escape through to shell
keybind = unconsumed:escape=text:\x1b

shell-integration = zsh
command = /opt/homebrew/bin/zsh -l
keybind = shift+enter=text:\x1b\r

# Cursor
cursor-style = block
cursor-style-blink = true
cursor-color = ff0099
cursor-opacity = 1.0
cursor-invert-fg-bg = true

# Background image from iTerm2
background-image = /Users/rch/Pictures/c1-logo.png
background-image-fit = contain
background-image-opacity = 0.095

# Vaporwave colors
background = 000000
foreground = ffffff
selection-background = aa00e8
selection-foreground = ffffff

# ANSI colors - canonical vaporwave palette
palette = 0=#1a1a2e
palette = 1=#ff0099
palette = 2=#5cecff
palette = 3=#fbb725
palette = 4=#aa00e8
palette = 5=#ff00f8
palette = 6=#5cecff
palette = 7=#ffffff
palette = 8=#333355
palette = 9=#ff0099
palette = 10=#5cecff
palette = 11=#fbb725
palette = 12=#aa00e8
palette = 13=#ff00f8
palette = 14=#5cecff
palette = 15=#ffffff

custom-shader = ./shaders/underwater-glitchy.glsl

# Focus follows mouse
focus-follows-mouse = true

# Inactive split dimming
unfocused-split-opacity = 0.7
unfocused-split-fill = 1a0030

# Window styling
macos-titlebar-style = transparent
macos-window-shadow = false
window-padding-balance = true

# Text styling
bold-is-bright = true

# Memory management
scrollback-limit = 10000
