      "Bash(pwd)",
      "Bash(env)",
      "Bash(printenv:*)",
      "Bash(date:*)",
      "Bash(uname:*)",
      "Bash(hostname)",
      "Bash(whoami)",
      "Bash(id)",
      "Bash(ps:*)",
      "Bash(pgrep:*)",
      "Bash(top -l 1:*)",
      "Bash(lsof:*)",
      "Bash(jq:*)",
      "Bash(yq:*)",
      "Bash(eza:*)",
      "Bash(bat:*)",
