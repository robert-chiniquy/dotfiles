      "Bash(md5sum:*)",
      "Bash(shasum:*)",
      "Bash(openssl:*)",
      "Bash(xxd:*)",
      "Bash(hexdump:*)",
      "Bash(strings:*)",
      "Bash(nm:*)",
      "Bash(otool:*)",
      "Bash(lipo -info:*)",
      "Bash(sw_vers:*)",
      "Bash(xcode-select:*)",
      "Bash(brew:*)",
      "Bash(golangci-lint:*)",
      "Bash(gofmt:*)",
      "Bash(buf:*)",
      "Bash(speakeasy:*)",
      "Bash(defaults:*)",
      "Bash(launchctl:*)",
      "Bash(source:*)",
      "Bash(set -e)",
      "Bash(wait)",
      "Bash(yes y *)",
      "Bash(claude --version)",
      "Bash(codex --version)",
      "Bash(iterm-pane-purple)",
      "Bash(iterm-pane-reset)",
      "Bash(~/bin/iterm-pane-purple)",
      "Bash(~/bin/iterm-pane-reset)",
      "Bash(rtk:*)",
      "Bash(bd:*)",
      "Bash(~/.local/bin/bd:*)",
      "Bash(squire:*)",
      "Bash(SQUIRE_DEBUG=1 squire env)",
      "Bash(sqfan:*)",
      "Bash(~/.local/bin/sqfan:*)",
      "Bash(/Users/rch/.local/bin/sqfan:*)",
      "Bash(build/sqfan:*)",
      "Bash(./build/sqfan:*)",
      "Bash(/Users/rch/repo/sqfan/build/sqfan:*)",
      "Read(//Users/rch/.local/bin/**)",
      "Read(//Users/rch/.sqfan/**)",
      "Read(//Users/rch/repo/**)",
      "Read(//tmp/**)",
      "Read(//private/tmp/**)",
      "mcp__codebase-memory-mcp__index_repository",
      "mcp__codebase-memory-mcp__index_status",
      "mcp__codebase-memory-mcp__search_graph",
      "mcp__codebase-memory-mcp__search_code",
      "mcp__codebase-memory-mcp__get_code_snippet",
      "mcp__codebase-memory-mcp__get_architecture",
      "mcp__codebase-memory-mcp__get_graph_schema",
      "mcp__codebase-memory-mcp__trace_path",
      "mcp__codebase-memory-mcp__query_graph",
      "mcp__codebase-memory-mcp__list_projects",
      "mcp__codebase-memory-mcp__detect_changes"
    ],
    "defaultMode": "acceptEdits"
  },
  "model": "fable",
  "hooks": {
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bd prime"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/rch/.claude/hooks/block-cd.sh"
          },
          {
            "type": "command",
            "command": "/Users/rch/.claude/hooks/block-subagent-destructive.sh"
          },
          {
            "type": "command",
            "command": "/Users/rch/.claude/hooks/rtk-rewrite.sh"
          }
        ]
      },
      {
        "matcher": "Grep|Glob|Read|Search",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/cbm-code-discovery-gate"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bd prime"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/cbm-session-reminder"
          },
          {
            "type": "command",
            "command": "sqfan prime --brief"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/large-transcript-warn"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "/Users/rch/bin/claude-statusline"
  },
  "enabledPlugins": {
    "claude-hud@claude-hud": true,
    "gopls-lsp@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": false,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "swift-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "claude-hud": {
      "source": {
        "source": "github",
        "repo": "jarrodwatts/claude-hud"
      }
    }
  },
  "spinnerVerbs": {
    "mode": "replace",
    "verbs": [
      "Working"
    ]
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "xhigh",
  "tui": "fullscreen",
  "skipWorkflowUsageWarning": true,
  "editorMode": "normal",
  "verbose": true
}
