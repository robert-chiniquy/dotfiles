#!/usr/bin/env zsh
# prune-pink-wallpapers -- find and remove/move images that are too pink/
# magenta for the neon-grit aesthetic. Pinkness metric is (min(R,B) - G)
# averaged over the image, scaled ×100. Rust-warm tones (high R, low B, low G)
# score near zero or negative; magenta/pink (high R AND high B, low G) scores
# positive. Default threshold +10 catches vaporwave-saturated Copilot/ChatGPT
# outputs while sparing rust-toned natural images.
#
# Usage:
#   prune-pink-wallpapers [DIR]
#                         [--min-pink=10]   # above this is rejected
#                         [--bin=1.0]       # histogram bin size
#                         [--histogram]     # print histogram and exit
#                         [--delete]        # remove instead of moving
#                         [--dry-run]       # report only
#                         [--quiet]         # only summary line

set -euo pipefail

DIR="$HOME/Pictures/dynamic-wallpaper"
MIN_PINK=10
BIN=1.0
HISTOGRAM=0
DELETE=0
DRY_RUN=0
QUIET=0

for arg in "$@"; do
    case "$arg" in
        --min-pink=*) MIN_PINK="${arg#*=}" ;;
        --bin=*)      BIN="${arg#*=}" ;;
        --histogram)  HISTOGRAM=1 ;;
        --delete)     DELETE=1 ;;
        --dry-run)    DRY_RUN=1 ;;
        --quiet)      QUIET=1 ;;
        -h|--help)
            sed -n '1,/^set -euo/p' "$0" | sed '/^set/d; s/^# \{0,1\}//'
            exit 0 ;;
        --*) echo "unknown flag: $arg" >&2; exit 1 ;;
        *)   DIR="$arg" ;;
    esac
done

[[ -d "$DIR" ]] || { echo "not a directory: $DIR" >&2; exit 1; }
command -v magick >/dev/null || { echo "ImageMagick 7 (magick) required" >&2; exit 1; }

DATA=$(mktemp -t pink.XXXXXX)
trap '/bin/rm -f "$DATA"' EXIT

find "$DIR" -maxdepth 1 -type f \
    \( -iname '*.jpg' -o -iname '*.jpeg' -o -iname '*.png' \
       -o -iname '*.webp' -o -iname '*.heic' \) \
    -print0 | while IFS= read -r -d '' f; do
    p=$(magick "$f" -format "%[fx:(min(mean.r, mean.b) - mean.g)*100]" info: 2>/dev/null) || continue
    [[ -n "$p" ]] && printf '%s\t%s\n' "$p" "$f" >> "$DATA"
done

count=$(wc -l < "$DATA" | tr -d ' ')

if (( HISTOGRAM )); then
    printf '%d images scanned in %s\n\n' "$count" "$DIR"
    /usr/bin/awk -F'\t' '{print $1}' "$DATA" | sort -g > "${DATA}.s"
    n=$(wc -l < "${DATA}.s" | tr -d ' ')
    printf 'percentiles (negative = green-leaning, positive = pink/magenta):\n'
    for pct in 0 10 25 50 75 85 90 95 99 100; do
        idx=$(( (n * pct + 50) / 100 ))
        (( idx < 1 )) && idx=1
        (( idx > n )) && idx=n
        val=$(sed -n "${idx}p" "${DATA}.s")
        printf '  p%-3d = %.2f\n' "$pct" "$val"
    done
    printf '\nhistogram (%s bins):\n' "$BIN"
    /usr/bin/awk -v bin="$BIN" '
    { b = int($1 / bin); if ($1 < 0 && $1 != b * bin) b--; count[b]++;
      if (max == "" || b > max) max = b; if (min == "" || b < min) min = b }
    END {
        maxct = 0
        for (b in count) if (count[b] > maxct) maxct = count[b]
        for (b = min; b <= max; b++) {
            ct = count[b] + 0
            if (ct == 0) continue
            lo = b * bin; hi = (b+1) * bin - 0.01
            bar = ""; barlen = int(ct * 40 / maxct)
            if (barlen < 1) barlen = 1
            for (i = 0; i < barlen; i++) bar = bar "█"
            printf "  %+6.1f to %+6.1f  (%3d) %s\n", lo, hi, ct, bar
        }
    }' "${DATA}.s"
    /bin/rm -f "${DATA}.s"
    exit 0
fi

REJECT_DIR="${DIR%/}/.rejected"
[[ $DELETE -eq 0 && $DRY_RUN -eq 0 ]] && mkdir -p "$REJECT_DIR"

total=0; rejected=0; kept=0
while IFS=$'\t' read -r pink path; do
    total=$((total + 1))
    # Compare floats via awk (zsh's [[ ]] can't do float comparison)
    over=$(/usr/bin/awk -v p="$pink" -v t="$MIN_PINK" 'BEGIN{print (p > t) ? 1 : 0}')
    if (( over )); then
        rejected=$((rejected + 1))
        if (( DRY_RUN )); then
            (( QUIET )) || printf 'WOULD-REJECT  %+6.2f  %s\n' "$pink" "$path"
        elif (( DELETE )); then
            /bin/rm -f -- "$path"
            (( QUIET )) || printf 'DELETED       %+6.2f  %s\n' "$pink" "$path"
        else
            mv -- "$path" "$REJECT_DIR/"
            (( QUIET )) || printf 'MOVED         %+6.2f  %s\n' "$pink" "$path"
        fi
    else
        kept=$((kept + 1))
    fi
done < "$DATA"

printf '\nscanned=%d  kept=%d  rejected=%d  min_pink=%s' "$total" "$kept" "$rejected" "$MIN_PINK"
(( DRY_RUN )) && printf ' (dry-run)'
(( DELETE == 0 && DRY_RUN == 0 )) && printf '\nrejected files in: %s' "$REJECT_DIR"
echo
