#!/usr/bin/env zsh
# iterm-session-snapshot -- inventory open iTerm tabs (cwd + harness + agent
# session id) and emit a restore script that reopens a new iTerm window with
# a tab per captured session, cd'd to the cwd and resuming the agent in the
# right harness.
#
# Motivation: after a reboot / crash / machine migration, rebuild your working
# set in one command instead of hunting session IDs by hand.
#
# Harness detection per tab (by the foreground process on its tty):
#   claude → `claude --resume <session-id>`   (id = newest transcript for cwd)
#   codex  → `codex resume <session-id>`       (id = newest rollout for cwd)
#   grok   → `grok --resume <session-id>` if resolvable, else a plain shell
#   nu     → launches `nu` in the cwd
#   other  → a plain shell in the cwd
#
# Usage:
#   iterm-session-snapshot                 # inventory + write restore script to CWD
#   iterm-session-snapshot --list          # print inventory only, write nothing
#   iterm-session-snapshot -o PATH         # write restore script to PATH
#
# The emitted restore script is self-contained and portable: run it on this or
# another Mac (session IDs only resolve where the transcripts exist).

set -euo pipefail

MODE="write"
OUT=""
for arg in "$@"; do
  case "$arg" in
    --list|-l) MODE="list" ;;
    -o)        MODE="write"; OUT="__NEXT__" ;;
    *) if [ "$OUT" = "__NEXT__" ]; then OUT="$arg"; fi ;;
  esac
done
[ -z "$OUT" ] || [ "$OUT" = "__NEXT__" ] && OUT="./iterm-session-restore-$(/bin/date +%Y%m%d-%H%M%S).sh"

command -v osascript >/dev/null || { echo "osascript required (macOS + iTerm2)" >&2; exit 1; }

# --- 1. enumerate iTerm sessions: tty<TAB>cwd, one per line ---
sessions=$(/usr/bin/osascript <<'AS' 2>/dev/null
tell application "iTerm2"
  set out to ""
  repeat with w in windows
    repeat with t in tabs of w
      repeat with s in sessions of t
        set p to ""
        try
          set p to (variable s named "session.path")
        end try
        set out to out & (tty of s) & "\t" & p & linefeed
      end repeat
    end repeat
  end repeat
  return out
end tell
AS
)
[ -n "$sessions" ] || { echo "no iTerm sessions found (is iTerm2 running?)" >&2; exit 1; }

# --- helpers ---
# newest claude transcript for a cwd → session id (basename sans .jsonl)
claude_sid_for() {
  local cwd="$1" mangled proj f
  mangled="${cwd//\//-}"                     # /Users/rch/x → -Users-rch-x
  proj="$HOME/.claude/projects/$mangled"
  [ -d "$proj" ] || return 1
  f=$(/bin/ls -t "$proj"/*.jsonl 2>/dev/null | /usr/bin/head -1) || return 1
  [ -n "$f" ] || return 1
  basename "$f" .jsonl
}
# newest codex rollout whose recorded cwd matches → session uuid
codex_sid_for() {
  local cwd="$1" f
  # rollout filenames end in <uuid>.jsonl; the cwd is recorded in the head
  f=$(/usr/bin/find "$HOME/.codex/sessions" -name 'rollout-*.jsonl' -type f 2>/dev/null \
      | /usr/bin/xargs -I{} /bin/sh -c '/usr/bin/head -c 4000 "{}" | /usr/bin/grep -ql "\"cwd\":\"'"$cwd"'\"" && /usr/bin/stat -f "%m %N" "{}"' 2>/dev/null \
      | /usr/bin/sort -rn | /usr/bin/head -1 | /usr/bin/awk '{print $2}')
  [ -n "$f" ] || return 1
  basename "$f" .jsonl | /usr/bin/sed -E 's/^rollout-[0-9T:-]+-//'
}
# foreground harness on a tty device
harness_on() {
  local dev="$1"
  /bin/ps -t "$dev" -o command= 2>/dev/null \
    | /usr/bin/grep -viE '^-|login|(^| )-?/?(bin/)?(z|ba)?sh$' \
    | /usr/bin/grep -oiE 'claude|codex|grok|^nu$| nu$' | /usr/bin/head -1 \
    | /usr/bin/tr 'A-Z' 'a-z' | /usr/bin/tr -d ' '
}

# --- 2. build the inventory rows: cwd | harness | resume-cmd ---
typeset -a ROWS
while IFS=$'\t' read -r tty cwd; do
  [ -n "$tty" ] || continue
  [ -n "$cwd" ] || continue
  dev="${tty##*/}"
  h=$(harness_on "$dev" || true)
  case "$h" in
    claude) sid=$(claude_sid_for "$cwd" 2>/dev/null || true)
            cmd=$([ -n "$sid" ] && echo "claude --resume $sid" || echo "claude") ;;
    codex)  sid=$(codex_sid_for "$cwd" 2>/dev/null || true)
            cmd=$([ -n "$sid" ] && echo "codex resume $sid" || echo "codex") ;;
    grok)   cmd="grok" ;;
    nu)     cmd="nu" ;;
    *)      h="shell"; cmd="" ;;
  esac
  ROWS+=("$cwd"$'\t'"$h"$'\t'"$cmd")
done <<< "$sessions"

# --- 3a. list mode ---
if [ "$MODE" = "list" ]; then
  printf '%-45s %-8s %s\n' "CWD" "HARNESS" "RESUME"
  for r in "${ROWS[@]}"; do
    IFS=$'\t' read -r cwd h cmd <<< "$r"
    printf '%-45s %-8s %s\n' "$cwd" "$h" "${cmd:-<shell>}"
  done
  exit 0
fi

# --- 3b. write a self-contained restore script (osascript-driven) ---
{
  echo '#!/usr/bin/env zsh'
  echo '# Auto-generated by iterm-session-snapshot. Reopens a new iTerm window'
  echo "# with one tab per captured session. Generated $(/bin/date)."
  echo 'set -eu'
  echo 'osascript <<APPLESCRIPT'
  echo 'tell application "iTerm2"'
  echo '  set newWin to (create window with default profile)'
  first=1
  for r in "${ROWS[@]}"; do
    IFS=$'\t' read -r cwd h cmd <<< "$r"
    # shell-escape the cd + command for the AppleScript "write text" line
    if [ -n "$cmd" ]; then
      line="cd \\\"$cwd\\\" && $cmd"
    else
      line="cd \\\"$cwd\\\""
    fi
    if [ "$first" = "1" ]; then
      echo "  tell current session of newWin to write text \"$line\""
      first=0
    else
      echo '  tell newWin'
      echo '    set newTab to (create tab with default profile)'
      echo "    tell current session of newTab to write text \"$line\""
      echo '  end tell'
    fi
  done
  echo 'end tell'
  echo 'APPLESCRIPT'
} > "$OUT"
chmod +x "$OUT"

echo "wrote restore script: $OUT"
echo "  ${#ROWS[@]} session(s) captured"
echo "  review it, then run: $OUT"
