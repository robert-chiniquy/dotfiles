#!/bin/bash
# Toggle vaporwave overlay on inactive windows only (active window stays clear)
# Usage: vvw

if pkill -9 -f vaporwave-overlay 2>/dev/null; then
    echo "Off"
else
    ~/Applications/VaporwaveOverlay.app/Contents/MacOS/vaporwave-overlay 2> >(while read -r line; do printf '\033[90m%s\033[0m\n' "$line"; done) 1>/dev/null &
    echo "On"
fi
echo -e "\r"
